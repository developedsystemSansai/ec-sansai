<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ตั้งรหัสผ่านใหม่ — EC Sansai</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=Prompt:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-dark: #1a6b3a;
            --green-main: #2d8a52;
            --green-mid: #3aa66b;
            --green-light: #e8f5ee;
            --green-pale: #f2faf5;
            --accent: #f0a500;
            --red: #d93025;
            --red-light: #fce8e6;
            --blue: #1565c0;
            --blue-light: #e8f0fe;
            --text-dark: #1a2e1e;
            --text-mid: #3d5c46;
            --text-light: #6b8c74;
            --border: #c8dfd0;
            --white: #fff;
            --bg: #f5f9f6;
            --shadow-lg: 0 8px 32px rgba(0,0,0,.12);
            --radius-lg: 16px;
            --radius: 10px;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Sarabun', sans-serif;
            background: linear-gradient(135deg, #0f4027, #1a6b3a 40%, #2d8a52);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .reset-card {
            background: #fff;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            padding: 40px;
            width: 100%;
            max-width: 420px;
            animation: slideUp .4s ease;
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .reset-header {
            text-align: center;
            margin-bottom: 28px;
        }
        .reset-header h2 {
            font-family: 'Prompt', sans-serif;
            font-size: 18px;
            color: var(--green-dark);
            margin-top: 10px;
        }
        .reset-header p {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 4px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-mid);
            margin-bottom: 6px;
        }
        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            font-family: 'Sarabun', sans-serif;
            font-size: 15px;
            transition: all .2s;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--green-main);
            box-shadow: 0 0 0 3px rgba(45,138,82,.12);
        }
        .password-wrap {
            position: relative;
        }
        .toggle-pw {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-light);
            font-size: 16px;
            padding: 0;
        }
        .strength-bar {
            height: 4px;
            border-radius: 2px;
            margin-top: 4px;
            background: var(--border);
            overflow: hidden;
        }
        .strength-fill {
            height: 100%;
            border-radius: 2px;
            transition: width .3s, background .3s;
            width: 0;
        }
        .hint-text {
            font-size: 11px;
            color: var(--text-light);
            margin-top: 3px;
        }
        .btn-reset {
            width: 100%;
            padding: 14px;
            background: var(--green-main);
            color: #fff;
            border: none;
            border-radius: var(--radius);
            font-family: 'Prompt', sans-serif;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            margin-top: 8px;
        }
        .btn-reset:hover {
            background: var(--green-dark);
        }
        .btn-reset:disabled {
            background: #aaa;
            cursor: not-allowed;
        }
        .alert {
            padding: 12px 16px;
            border-radius: var(--radius);
            font-size: 14px;
            margin-bottom: 16px;
        }
        .alert-success {
            background: var(--green-light);
            color: var(--green-dark);
            border: 1px solid var(--green-mid);
        }
        .alert-error {
            background: var(--red-light);
            color: var(--red);
            border: 1px solid #f5bcb8;
        }
        .login-link {
            text-align: center;
            margin-top: 16px;
            font-size: 13px;
        }
        .login-link a {
            color: var(--green-main);
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }
        .spin-sm {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .6s linear infinite;
            vertical-align: middle;
            margin-right: 6px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="reset-card">
        <div class="reset-header">
            <div style="font-size: 48px;">🔐</div>
            <h2>ตั้งรหัสผ่านใหม่</h2>
            <p>EC Online Submission — โรงพยาบาลสันทราย</p>
        </div>

        <div id="message-container"></div>

        <form id="reset-form" onsubmit="handleReset(event)">
            <div class="form-group">
                <label>รหัสผ่านใหม่ <span style="color: var(--red)">*</span></label>
                <div class="password-wrap">
                    <input type="password" id="new-password" class="form-control" 
                           placeholder="อย่างน้อย 8 ตัว" required minlength="8"
                           oninput="checkStrength(this.value)">
                    <button class="toggle-pw" type="button" onclick="togglePw('new-password', this)">👁</button>
                </div>
                <div class="strength-bar">
                    <div class="strength-fill" id="strength-fill"></div>
                </div>
                <div class="hint-text" id="strength-label"></div>
            </div>

            <div class="form-group">
                <label>ยืนยันรหัสผ่านใหม่ <span style="color: var(--red)">*</span></label>
                <div class="password-wrap">
                    <input type="password" id="confirm-password" class="form-control" 
                           placeholder="กรอกรหัสผ่านอีกครั้ง" required>
                    <button class="toggle-pw" type="button" onclick="togglePw('confirm-password', this)">👁</button>
                </div>
            </div>

            <button type="submit" class="btn-reset" id="reset-btn">
                ตั้งรหัสผ่านใหม่
            </button>

            <div class="login-link">
                <a onclick="goToLogin()">← กลับไปหน้าเข้าสู่ระบบ</a>
            </div>
        </form>
    </div>

    <script>
        // ============================================================
        // 🔐 SECURITY: รับ token จาก server-side template (GAS Web App ไม่รักษา query string ใน browser URL)
        // token ถูกตรวจสอบและฝังมาจาก doGet() แล้ว ปลอดภัยกว่าการอ่านจาก window.location.search
        // ============================================================
        var resetToken = '<?= resetToken ?>';

        // [SEC] ตรวจสอบรูปแบบ token เบื้องต้นก่อนส่งไป server
        // UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
        function isValidTokenFormat(token) {
            if (!token) return false;
            if (token.length > 100) return false;
            return /^[a-zA-Z0-9\-]+$/.test(token);
        }

        if (!resetToken || !isValidTokenFormat(resetToken)) {
            showMessage('error', 'ไม่พบข้อมูลการรีเซ็ตรหัสผ่าน กรุณาขอใหม่');
            document.getElementById('reset-form').style.display = 'none';
        }

        // [SEC] ป้องกัน double-submit — track ว่ากำลังส่งอยู่หรือไม่
        var _isSubmitting = false;

        function handleReset(e) {
            e.preventDefault();

            // [SEC] ป้องกัน double-submit
            if (_isSubmitting) return;

            var newPass = document.getElementById('new-password').value;
            var confirmPass = document.getElementById('confirm-password').value;

            // ตรวจสอบความยาว
            if (newPass.length < 8) {
                showMessage('error', 'รหัสผ่านต้องมีอย่างน้อย 8 ตัวอักษร');
                return;
            }

            // ตรวจสอบความแข็งแรง
            if (!/(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/.test(newPass)) {
                showMessage('error', 'รหัสผ่านต้องประกอบด้วย ตัวพิมพ์เล็ก ตัวพิมพ์ใหญ่ และตัวเลข');
                return;
            }

            // ตรวจสอบว่ารหัสผ่านตรงกัน
            if (newPass !== confirmPass) {
                showMessage('error', 'รหัสผ่านไม่ตรงกัน');
                return;
            }

            var btn = document.getElementById('reset-btn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spin-sm"></span> กำลังดำเนินการ...';
            _isSubmitting = true;

            // ============================================================
            // 🔐 SECURITY CHANGE: เรียก resetPasswordSecure แทน resetPassword
            //    resetPasswordSecure ทำงานเหมือนเดิมทุกอย่าง แต่เพิ่ม:
            //    - ตรวจสอบ token format
            //    - ป้องกัน token reuse (mark used ก่อน)
            //    - บันทึก AuditLog ทุกครั้ง
            // ============================================================
            google.script.run
                .withSuccessHandler(function(response) {
                    btn.disabled = false;
                    btn.innerHTML = 'ตั้งรหัสผ่านใหม่';
                    _isSubmitting = false;

                    if (response.success) {
                        showMessage('success', 'ตั้งรหัสผ่านใหม่สำเร็จ! กำลังพากลับหน้าเข้าสู่ระบบ...');
                        // [SEC] ลบ token จาก URL หลังใช้งาน
                        if (window.history && window.history.replaceState) {
                            window.history.replaceState({}, document.title, window.location.pathname);
                        }
                        setTimeout(goToLogin, 3000);
                    } else {
                        showMessage('error', response.message || 'เกิดข้อผิดพลาด กรุณาลองอีกครั้ง');
                    }
                })
                .withFailureHandler(function(error) {
                    btn.disabled = false;
                    btn.innerHTML = 'ตั้งรหัสผ่านใหม่';
                    _isSubmitting = false;
                    // [SEC] ไม่แสดง error detail ที่ละเอียดแก่ผู้ใช้
                    showMessage('error', 'เกิดข้อผิดพลาด กรุณาลองอีกครั้ง');
                    // log เฉพาะ console สำหรับ debug
                    console.error('Reset error:', error.message);
                })
                // 🔐 เปลี่ยนจาก .resetPassword เป็น .resetPasswordSecure
                .resetPasswordSecure(resetToken, newPass, confirmPass);
        }

        function checkStrength(password) {
            var fill = document.getElementById('strength-fill');
            var label = document.getElementById('strength-label');
            
            var score = 0;
            if (password.length >= 8) score++;
            if (password.length >= 12) score++;
            if (/[A-Z]/.test(password)) score++;
            if (/[0-9]/.test(password)) score++;
            if (/[^A-Za-z0-9]/.test(password)) score++;

            var colors = ['', '#e53935', '#fb8c00', '#f0a500', '#43a047', '#2d8a52'];
            var texts = ['', 'อ่อนมาก', 'อ่อน', 'ปานกลาง', 'แข็งแรง', 'แข็งแรงมาก'];

            fill.style.width = (score * 20) + '%';
            fill.style.background = colors[score] || colors[1];
            label.textContent = texts[score] || '';
            label.style.color = colors[score] || colors[1];
        }

        function togglePw(inputId, btn) {
            var input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                btn.textContent = '🙈';
            } else {
                input.type = 'password';
                btn.textContent = '👁';
            }
        }

        function showMessage(type, text) {
            var container = document.getElementById('message-container');
            var className = type === 'success' ? 'alert-success' : 'alert-error';
            // [SEC] escape text ก่อนแสดงใน HTML
            var safeText = String(text).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            container.innerHTML = '<div class="alert ' + className + '">' +
                (type === 'success' ? '✅ ' : '❌ ') + safeText + '</div>';
        }

        function goToLogin() {
            window.location.href = 'https://developedsystemSansai.github.io/ec-sansai';
        }
    </script>
</body>
</html>
